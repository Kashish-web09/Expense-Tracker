<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

<title>Expense Tracker</title>

<style>
body{
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #e0f7fa, #e8f5e9);
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100vh;
}

/* Header */
h1{
    margin-top: 30px;
    font-size: 36px;
    font-weight: 800;
    color: #2c3e50;
}

/* Card */
.card-box{
    width: 100%;
    max-width: 420px;
    background: #fff;
    padding: 25px;
    border-radius: 15px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    margin-top: 20px;
}

/* Labels */
label{
    font-weight: 600;
    color: #34495e;
}

/* Inputs */
.form-control{
    border-radius: 10px;
    padding: 10px;
    border: 1px solid #ccc;
    transition: 0.3s;
}

.form-control:focus{
    border-color: #26a69a;
    box-shadow: 0 0 5px rgba(38,166,154,0.4);
}

/* Button */
.btn-custom{
    background: #26a69a;
    border: none;
    color: white;
    font-weight: 600;
    border-radius: 10px;
    padding: 10px;
    transition: 0.3s;
}

.btn-custom:hover{
    background: #1e8e83;
}

/* Expense List */
.list-container{
    width: 100%;
    max-width: 500px;
    margin-top: 30px;
}

.list-item{
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #fff;
    padding: 12px 15px;
    border-radius: 12px;
    margin-bottom: 10px;
    box-shadow: 0 5px 10px rgba(0,0,0,0.05);
}

/* Buttons */
.btn-delete{
    background: #e74c3c;
    color: white;
    border: none;
    padding: 5px 10px;
    border-radius: 8px;
}

.btn-delete:hover{
    background: #c0392b;
}

.btn-edit{
    background: #f39c12;
    color: white;
    border: none;
    padding: 5px 10px;
    border-radius: 8px;
}

.btn-edit:hover{
    background: #d68910;
}

/* Total box */
.total-box{
    margin-top: 20px;
    background: #26a69a;
    color: white;
    padding: 12px;
    border-radius: 12px;
    font-weight: 600;
    text-align: center;
}
nav {
    width: 100%;
    display: flex;
    justify-content: flex-end; /* 👉 pushes to right */
    padding: 15px 30px 0 30px;
}

.nav-links {
    width: 100%;
    display: flex;
    justify-content: flex-end; /* 👉 right side */
    padding: 20px 40px 0 40px;
}

.breadcrumb {
    background: transparent;
    margin: 0;
    gap: 10px;
}

/* Remove default slash */
.breadcrumb-item + .breadcrumb-item::before {
    content: "";
}

/* Style links like buttons */
.breadcrumb a {
    text-decoration: none;
    font-weight: 600;
    color: #26a69a;
    padding: 6px 14px;
    border-radius: 20px;
    background: #e0f2f1;
    transition: 0.3s;
}

/* Hover effect */
.breadcrumb a:hover {
    background: #26a69a;
    color: white;
}

/* Active (Register) */
.breadcrumb-item.active a {
    background: #26a69a;
    color: white;
}/* Responsive */

@media(max-width: 500px){
    .card-box{
        margin: 15px;
    }
}
</style>
</head>

<body>

<%-body %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>