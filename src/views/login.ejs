<div class="card-box">
<form method="post" action="/login">

    <div class="mb-3">
        <label for="email">Email</label>
        <input type="email" class="form-control" placeholder="Enter mail id" name="email" id="email">
    </div>
    <div class="mb-3">
        <label for="password">Password</label>
        <input type="password" class="form-control" placeholder="Enter Password" name="password" id="password" step="8-20">
    </div>
<button type="submit" class="btn btn-custom w-100">Login</button>
</form>
<p style="margin-top: 10px; text-align: center; color: gray; float: left;"><a href="/forgot-password">Forgot password?</a></p>
<p style="margin-top: 10px; text-align: center; color: gray; float: right;"><a href="/register">Register</a></p>

</div>