
<h1>Update Expense </h1>

<div class="card-box">
<form method="post" action="/update">
    <div class="mb-3">
        <input type="hidden" name="id" value="<%=expense.id%>">
        <label for="name">Expense Name</label>
        <input type="text" id="name" class="form-control" name="name" value="<%=expense.name%>">
    </div>

    <div class="mb-3">
        <label for="amount">Amount</label>
        <input type="number" class="form-control" value="<%=expense.amount%>" name="amount" id="amount">
    </div>

<button type="submit" class="btn btn-custom w-100">Update</button>
</form>

</div>
